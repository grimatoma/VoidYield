; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Void Yield"
config/description="A top-down 2D active incremental game set in space."
run/main_scene="res://scenes/ui/main_menu.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")

[autoload]

GameState="*res://autoloads/game_state.gd"
ProducerData="*res://autoloads/producer_data.gd"
SaveManager="*res://autoloads/save_manager.gd"
AudioManager="*res://autoloads/audio_manager.gd"
SettingsManager="*res://autoloads/settings_manager.gd"
Recipes="*res://data/recipes.gd"
ColonyManager="*res://autoloads/colony_manager.gd"
TechTree="*res://autoloads/tech_tree.gd"
TechTreeData="*res://data/tech_tree_data.gd"
EventLog="*res://autoloads/event_log.gd"
RecipeRegistry="*res://autoloads/recipe_registry.gd"
StrandingManager="*res://autoloads/stranding_manager.gd"
GalaxyMap="*res://autoloads/galaxy_map.gd"
PlanetBStartup="*res://autoloads/planet_b_startup.gd"
LogisticsManager="*res://autoloads/logistics_manager.gd"
A2Depot="*res://autoloads/a2_depot.gd"
A2SecretCache="*res://autoloads/a2_secret_cache.gd"
A3Unlock="*res://autoloads/a3_unlock.gd"

[display]

window/size/viewport_width=960
window/size/viewport_height=540
window/size/mode=3
window/handheld/orientation="landscape"

[dotnet]

project/assembly_name="Void Yield"

[editor_plugins]

enabled=PackedStringArray("res://addons/TileMapDual/plugin.cfg")

